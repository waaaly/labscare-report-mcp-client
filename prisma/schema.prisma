// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// 枚举定义
enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum DocStatus {
  UPLOADING
  PROCESSING
  SUCCESS
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Lab {
  id               String   @id @default(cuid())
  name             String
  domain           String   @unique // 增加唯一约束
  token            String
  version          String
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  
  projects         Project[]
  reports          Report[]
  tasks            Task[]
  scripts          Script[]

  @@map("labs")
}

model Project {
  id          String   @id @default(cuid())
  labId       String   @map("lab_id")
  name        String
  limsPid     String   @unique @map("lims_pid")
  createdAt   DateTime @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at") // 软删除支持

  lab         Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)
  reports     Report[]
  documents   Document[]
  scripts     Script[]
  tasks       Task[]    // 建立直接关联

  @@index([labId])
  @@map("projects")
}

model Report {
  id          String   @id @default(cuid())
  labId       String   @map("lab_id")
  projectId   String   @map("project_id")
  name        String
  description String?   @map("description")
  createdAt   DateTime @default(now()) @map("created_at")
  
  lab         Lab      @relation(fields: [labId], references: [id]) // 2. 添加反向关联
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documents   Document[]
  tasks       Task[]
  scripts     Script[]

  @@index([labId, projectId])
  @@map("reports")
}

model Document {
  id          String    @id @default(cuid())
  projectId   String    @map("project_id")
  reportId    String   @map("report_id")
  name        String
  type        String  
  url         String
  status      DocStatus @default(UPLOADING) // 使用枚举
  size        BigInt?   // 升级为 BigInt 防止溢出
  storagePath String?   @map("storage_path")
  createdAt   DateTime  @default(now()) @map("created_at")
  pdf         String?
  cover       String?
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  report      Report?   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  // 添加这行，用于承接 Script 里的 dataSource 关系
  scripts     Script[] //scrpipt需要关联json作为datasource
  @@index([projectId, reportId, status,type]) // 优化查询索引
  @@map("documents")
}

model Task {
  id                     String         @id @default(cuid())
  labId                  String         @map("lab_id")
  projectId              String         @map("project_id") // 冗余项目ID提升性能
  reportId               String         @map("report_id")
  status                 TaskStatus     @default(PENDING) // 使用枚举
  progress               Int            @default(0)
  model                  String?        @default("claude-3-5-sonnet")
  duration               Int?           // 运行耗时（秒）
  createdAt              DateTime       @default(now()) @map("created_at")
  completedAt            DateTime?      @map("completed_at")
  
  lab                    Lab            @relation(fields: [labId], references: [id])
  project                Project        @relation(fields: [projectId], references: [id])
  report                 Report         @relation(fields: [reportId], references: [id])
  logs                   TaskLog[]
  scripts                Script[]       // 产物关联

  @@index([labId, status])
  @@index([projectId,reportId])
  @@map("tasks")
}

model Script {
  id          String   @id @default(cuid())
  labId       String   @map("lab_id")
  projectId   String   @map("project_id")
  reportId    String   @map("report_id")
  taskId      String   @map("task_id")    // 产物溯源
  name        String
  code        String   @db.Text           // 明确长文本类型
    // 核心字段：关联到数据源文档
  dataSourceId     String   @map("data_source_id")
  version     Int      @default(1)        // 版本管理
  createdAt   DateTime @default(now()) @map("created_at")
  
  lab         Lab      @relation(fields: [labId], references: [id]) // 2. 添加反向关联
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
 // 关系映射
  dataSource       Document @relation(fields: [dataSourceId], references: [id])

  @@index([taskId,dataSourceId])
  @@unique([taskId, name]) // 同一个任务生成的产物名唯一
  @@map("scripts")
}

model TaskLog {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  timestamp DateTime @default(now())
  level     String   @default("INFO") // 增加日志级别（INFO/ERROR）
  content   String   @db.Text
  
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, timestamp])
  @@map("task_logs")
}

// ========== 对话上下文系统 ==========

model Conversation {
  id          String   @id @default(cuid())
  title       String   @default("新对话")
  model       String   @default("gpt-4o") // 使用的模型
  
  // 系统状态（可选关联）
  labId       String?  @map("lab_id")
  projectId   String?  @map("project_id")
  reportId    String?  @map("report_id")
  
  // Token 统计
  totalInputTokens   Int      @default(0) @map("total_input_tokens")
  totalOutputTokens  Int      @default(0) @map("total_output_tokens")
  totalTokens        Int      @default(0) @map("total_tokens")
  messageCount       Int      @default(0) @map("message_count")
  
  // 元数据
  metadata    Json?    @default("{}") // 存储额外配置、用户偏好等
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // 关联
  messages    Message[]
  
  @@index([createdAt])
  @@map("conversations")
}

model Message {
  id              String      @id @default(cuid())
  conversationId  String      @map("conversation_id")
  role            MessageRole
  
  // 内容（文本或结构化内容）
  content         String      @db.Text
  contentType     String      @default("text") @map("content_type") // text, image, json, mixed
  
  // 消息类型标记
  messageType     String?     @map("message_type") // thought, tool_call, status, content
  toolName        String?     @map("tool_name")    // 如果是工具调用
  toolInput       Json?       @map("tool_input")   // 工具输入参数
  toolOutput      Json?       @map("tool_output")  // 工具输出结果
  
  // Token 使用（单条消息）
  inputTokens     Int?        @map("input_tokens")
  outputTokens    Int?        @map("output_tokens")
  
  // 文件附件（存储引用）
  attachments     Json?       @default("[]") // [{name, type, url, size}]
  
  // 元数据
  metadata        Json?       @default("{}") // 额外信息如生成时间、模型版本等
  
  // 排序
  sequence        Int         @default(0)
  
  createdAt       DateTime    @default(now()) @map("created_at")
  
  // 关联
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId, sequence])
  @@index([createdAt])
  @@map("messages")
}
