// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// 枚举定义
enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum DocStatus {
  UPLOADING
  PROCESSING
  SUCCESS
  FAILED
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Lab {
  id               String   @id @default(cuid())
  name             String
  domain           String   @unique // 增加唯一约束
  token            String
  version          String
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  
  projects         Project[]
  reports          Report[]
  tasks            Task[]
  scripts          Script[]

  @@map("labs")
}

model Project {
  id          String   @id @default(cuid())
  labId       String   @map("lab_id")
  name        String
  limsPid     String   @unique @map("lims_pid")
  createdAt   DateTime @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at") // 软删除支持

  lab         Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)
  reports     Report[]
  documents   Document[]
  scripts     Script[]
  tasks       Task[]    // 建立直接关联

  @@index([labId])
  @@map("projects")
}

model Report {
  id          String   @id @default(cuid())
  labId       String   @map("lab_id")
  projectId   String   @map("project_id")
  name        String
  description String?   @map("description")
  createdAt   DateTime @default(now()) @map("created_at")
  
  lab         Lab      @relation(fields: [labId], references: [id]) // 2. 添加反向关联
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documents   Document[]
  tasks       Task[]
  scripts     Script[]

  @@index([labId, projectId])
  @@map("reports")
}

model Document {
  id          String    @id @default(cuid())
  projectId   String    @map("project_id")
  reportId    String   @map("report_id")
  name        String
  type        String  
  url         String
  status      DocStatus @default(UPLOADING) // 使用枚举
  size        BigInt?   // 升级为 BigInt 防止溢出
  storagePath String?   @map("storage_path")
  createdAt   DateTime  @default(now()) @map("created_at")
  pdf         String?
  cover       String?
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  report      Report?   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  // 添加这行，用于承接 Script 里的 dataSource 关系
  scripts     Script[] //scrpipt需要关联json作为datasource
  @@index([projectId, reportId, status,type]) // 优化查询索引
  @@map("documents")
}

model Task {
  id                     String         @id @default(cuid())
  labId                  String         @map("lab_id")
  projectId              String         @map("project_id") // 冗余项目ID提升性能
  reportId               String         @map("report_id")
  status                 TaskStatus     @default(PENDING) // 使用枚举
  progress               Int            @default(0)
  model                  String?        @default("claude-3-5-sonnet")
  duration               Int?           // 运行耗时（秒）
  createdAt              DateTime       @default(now()) @map("created_at")
  completedAt            DateTime?      @map("completed_at")
  
  lab                    Lab            @relation(fields: [labId], references: [id])
  project                Project        @relation(fields: [projectId], references: [id])
  report                 Report         @relation(fields: [reportId], references: [id])
  logs                   TaskLog[]
  scripts                Script[]       // 产物关联

  @@index([labId, status])
  @@index([projectId,reportId])
  @@map("tasks")
}

model Script {
  id          String   @id @default(cuid())
  labId       String   @map("lab_id")
  projectId   String   @map("project_id")
  reportId    String   @map("report_id")
  taskId      String   @map("task_id")    // 产物溯源
  name        String
  code        String   @db.Text           // 明确长文本类型
    // 核心字段：关联到数据源文档
  dataSourceId     String   @map("data_source_id")
  version     Int      @default(1)        // 版本管理
  createdAt   DateTime @default(now()) @map("created_at")
  
  lab         Lab      @relation(fields: [labId], references: [id]) // 2. 添加反向关联
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
 // 关系映射
  dataSource       Document @relation(fields: [dataSourceId], references: [id])

  @@index([taskId,dataSourceId])
  @@unique([taskId, name]) // 同一个任务生成的产物名唯一
  @@map("scripts")
}

model TaskLog {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  timestamp DateTime @default(now())
  level     String   @default("INFO") // 增加日志级别（INFO/ERROR）
  content   String   @db.Text
  
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, timestamp])
  @@map("task_logs")
}
